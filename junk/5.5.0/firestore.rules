rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function validScore() {
      let s = request.resource.data.score;
      return s is int && s >= 0 && s <= 9999; // O1: hard cap at 9999
    }

    function validInitials() {
      let ini = request.resource.data.initials;
      return ini is string && ini.size() >= 1 && ini.size() <= 8; // O2: confirmed
    }

    function validBadge() {
      return !('badge' in request.resource.data) ||
             (request.resource.data.badge is string && request.resource.data.badge.size() <= 24);
    }

    function validDate() {
      let d = request.resource.data.date;
      return d is string && d.size() == 10 && d.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function hasRequiredFields() {
      // O3: required fields must all be present
      return request.resource.data.keys().hasAll(['score', 'initials', 'date', 'mode']);
    }

    match /lb_global/{docId} {
      allow read: if true;
      allow create: if
        hasRequiredFields() &&      // O3
        validScore() &&             // O1
        validInitials() &&          // O2
        validBadge() &&
        validDate() &&
        request.resource.data.mode in ['classic', 'evolve'] &&
        // score-per-tick guard
        (!('tick' in request.resource.data) ||
          (request.resource.data.tick is int &&
           request.resource.data.tick >= 0 &&
           request.resource.data.score <= request.resource.data.tick * 3 + 50)) &&
        request.resource.data.keys().hasOnly(['score', 'initials', 'date', 'mode', 'badge', 'ts', 'tick']) &&
        request.resource.data.ts == request.time; // O4: ts must match server time — prevents client clock manipulation
      allow update, delete: if false; // O5: write-once
    }

    match /dust_wallet/{docId} {
      allow read: if true;
      allow create, update: if
        request.resource.data.keys().hasOnly(['name', 'dust', 'ts']) &&
        request.resource.data.ts == request.time &&
        request.resource.data.name == docId &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 20 &&
        request.resource.data.dust is int &&
        request.resource.data.dust >= 0 &&
        request.resource.data.dust < 1000000;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
