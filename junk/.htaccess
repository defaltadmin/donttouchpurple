RewriteEngine On
# ── Cache Control ──────────────────────────────────────────────
# Never cache index.html (always fetch fresh)
<Files "index.html">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</Files>

# Cache JS/CSS/fonts aggressively (Vite hashes filenames on each build)
<FilesMatch "\.(js|css|woff2|woff|ttf)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
# ───────────────────────────────────────────────────────────────

# 1. Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# 2. Handle React Routing (SPA)
# This ensures that if you refresh the page on a sub-route, it doesn't 404
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

