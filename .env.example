VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
# HMAC secret for challenge URL signing — use a long random string in production
VITE_CHALLENGE_SECRET=replace-with-a-long-random-secret
# Dev overlay password (dev builds only)
VITE_DEV_PASSWORD=replace-with-dev-password
# Sentry sourcemap upload (CI only — do NOT commit real values)
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
